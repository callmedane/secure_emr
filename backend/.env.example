FLASK_ENV=development
DATABASE_URL=mysql+pymysql://emr_user:emr_password@localhost:3306/secure_emr
JWT_SECRET_KEY=replace-with-a-strong-random-secret
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
FRONTEND_ORIGIN=http://localhost:5173
ADDITIONAL_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:3000
RATELIMIT_STORAGE_URI=memory://
ADMIN_REGISTRATION_KEY=replace-with-private-admin-registration-key
MFA_ISSUER_NAME=Secure EMR
LOCKOUT_THRESHOLD=5
LOCKOUT_MINUTES=15
MFA_ENROLLMENT_MINUTES=15
ENFORCE_SECURE_CONFIG=false
